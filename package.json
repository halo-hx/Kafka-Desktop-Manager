{
  "name": "kafka-desktop-manager",
  "productName": "Kafka Desktop Manager",
  "description": "A modern, cross-platform desktop GUI for Apache Kafka built with Tauri, React and Rust.",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Jinjie He",
    "email": "jinjie_he@outlook.com"
  },
  "homepage": "https://github.com/halo-hx/Kafka-Desktop-Manager#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/halo-hx/Kafka-Desktop-Manager.git"
  },
  "bugs": {
    "url": "https://github.com/halo-hx/Kafka-Desktop-Manager/issues"
  },
  "keywords": [
    "kafka",
    "apache-kafka",
    "gui",
    "desktop",
    "tauri",
    "react",
    "rust",
    "schema-registry",
    "kafka-connect"
  ],
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md,json}\"",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-virtuoso": "^4.18.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
